{
  "name": "cv-manager",
  "slug": "La solution intelligente pour vos candidatures",
  "version": "0.0.1",
  "description": "CV Manager est une application moderne conçue pour centraliser et optimiser la gestion des candidatures. Le projet adopte une architecture robuste permettant une séparation claire entre la logique métier et l'interface utilisateur.",
  "keywords": [
    "React.JS",
    "NestJS",
    "MySQL"
  ],
  "homepage": "https://github.com/DevFredRX/CV-Manager#readme",
  "bugs": {
    "url": "https://github.com/DevFredRX/CV-Manager/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/DevFredRX/CV-Manager.git"
  },
  "license": "MIT",
  "author": "FredRX",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run start:dev --prefix server",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1"
  }
}
